OPENROUTER_API_KEY=sk-or-...
TELEGRAM_BOT_TOKEN=...
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

AIDER_MODEL=openrouter/deepseek/deepseek-chat
AIDER_WEAK_MODEL=openrouter/deepseek/deepseek-chat

PROJECT_AVI_WEBAPP=
PROJECT_AVI_ORCHESTRATOR=

# Opcional: comando de tests por proyecto (para /tests). Default: detecta pytest / npm test.
# PROJECT_WEBAPP_TEST_CMD=npm test
# PROJECT_ORCHESTRATOR_TEST_CMD=pytest -q

# Cap diario en USD. Si los crons se exceden, se saltan hasta la siguiente medianoche.
DAILY_BUDGET_USD=1.00

# Heartbeat: reporte diario de salud del bot. Vacío = deshabilitado.
HEARTBEAT_CRON=0 8 * * *
# Si no se define, usa el user_id más chico de TELEGRAM_ALLOWED_USER_IDS.
# HEARTBEAT_CHAT_ID=
